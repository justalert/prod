<IfModule mod_rewrite.c>
    RewriteEngine On

    # Dacă fișierul cerut există fizic (ex: /css/style.css), nu face nimic
    RewriteCond %{REQUEST_FILENAME} !-f
    # Dacă folderul cerut există fizic, nu face nimic
    RewriteCond %{REQUEST_FILENAME} !-d

    # Pentru orice altă rută (ex: /login, /api/subscribe), rutează totul prin index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
